components:
  schemas:
    ATR:
      type: object
      properties:
        id:
          type: integer
          readOnly: true
        reference_number:
          type: string
          maxLength: 50
        hiring_supervisor_name:
          type: string
          maxLength: 200
        position_title:
          type: string
          maxLength: 200
        roles_to_fill:
          type: integer
        due_date:
          type: string
          format: date
          nullable: true
        budgeted:
          type: boolean
        budget_amount:
          type: string
          format: decimal
          pattern: ^-?\d{0,10}(?:\.\d{0,2})?$
          nullable: true
        actual_amount:
          type: string
          format: decimal
          pattern: ^-?\d{0,10}(?:\.\d{0,2})?$
          nullable: true
        zambian_junior:
          type: integer
        zambian_senior:
          type: integer
        expatriate:
          type: integer
        use_internal_db:
          type: boolean
        internal_advertising:
          type: boolean
        external_advertising:
          type: boolean
        hr_db_search:
          type: boolean
        recruitment_agencies:
          type: boolean
        hr_manager_name:
          type: string
          maxLength: 200
        hr_manager_signed_at:
          type: string
          format: date
          nullable: true
        ops_manager_name:
          type: string
          maxLength: 200
        ops_manager_signed_at:
          type: string
          format: date
          nullable: true
        director_name:
          type: string
          maxLength: 200
        director_signed_at:
          type: string
          format: date
          nullable: true
        notes:
          type: string
        created_at:
          type: string
          format: date-time
          readOnly: true
        updated_at:
          type: string
          format: date-time
          readOnly: true
        department:
          type: integer
      required:
      - created_at
      - department
      - hiring_supervisor_name
      - id
      - position_title
      - reference_number
      - updated_at
    AlertTypeEnum:
      enum:
      - TRAINING
      - MEDICAL
      - PERMIT
      - CONTRACT
      - PROBATION
      type: string
      description: |-
        * `TRAINING` - Training Expiry
        * `MEDICAL` - Medical Expiry
        * `PERMIT` - Permit Expiry
        * `CONTRACT` - Contract Expiry
        * `PROBATION` - Probation Due
    Candidate:
      type: object
      properties:
        id:
          type: integer
          readOnly: true
        atr_reference:
          type: string
          readOnly: true
        engaged_date:
          type: string
          format: date
        name:
          type: string
          maxLength: 200
        nrc:
          type: string
          maxLength: 50
        phone_number:
          type: string
          maxLength: 30
        position:
          type: string
          maxLength: 200
        agreed_net_pay:
          type: string
          maxLength: 100
        accommodation:
          type: string
          maxLength: 200
        docs_submitted:
          type: boolean
        recommendation_date:
          type: string
          format: date
          nullable: true
        interview_due_date:
          type: string
          format: date
          nullable: true
        silicosis_status:
          type: string
          maxLength: 50
        medicals_status:
          type: string
          maxLength: 50
        ibf_status:
          type: string
          maxLength: 50
        initial_induction_status:
          type: string
          maxLength: 50
        company_induction_status:
          type: string
          maxLength: 50
        site_permit_status:
          type: string
          maxLength: 50
        pit_permit_status:
          type: string
          maxLength: 50
        pit_operation_permit_status:
          type: string
          maxLength: 50
        ohs_status:
          type: string
          maxLength: 50
        status:
          type: string
          maxLength: 50
        created_at:
          type: string
          format: date-time
          readOnly: true
        updated_at:
          type: string
          format: date-time
          readOnly: true
        atr:
          type: integer
          nullable: true
      required:
      - atr_reference
      - created_at
      - engaged_date
      - id
      - name
      - position
      - updated_at
    CaseStudy:
      type: object
      properties:
        id:
          type: integer
          readOnly: true
        case_number:
          type: string
          maxLength: 100
        related_report:
          type: integer
        related_report_number:
          type: string
          readOnly: true
        related_employee:
          type: integer
        related_employee_name:
          type: string
          readOnly: true
        status:
          $ref: '#/components/schemas/CaseStudyStatusEnum'
        verdict:
          $ref: '#/components/schemas/VerdictEnum'
        charges_document:
          type: string
          format: uri
        charges_text:
          type: string
        hearings_count:
          type: string
          readOnly: true
        investigations_count:
          type: string
          readOnly: true
        final_verdict_text:
          type: string
        sanctions_imposed:
          type: string
        appeal_status:
          type: string
          maxLength: 50
        case_opened_date:
          type: string
          format: date
          readOnly: true
        case_closed_date:
          type: string
          format: date
          nullable: true
        created_at:
          type: string
          format: date-time
          readOnly: true
        updated_at:
          type: string
          format: date-time
          readOnly: true
      required:
      - case_number
      - case_opened_date
      - created_at
      - hearings_count
      - id
      - investigations_count
      - related_employee
      - related_employee_name
      - related_report
      - related_report_number
      - updated_at
    CaseStudyStatusEnum:
      enum:
      - OPENED
      - UNDER_REVIEW
      - HEARING_PENDING
      - INVESTIGATION_PENDING
      - VERDICT_PENDING
      - CLOSED
      type: string
      description: |-
        * `OPENED` - Opened
        * `UNDER_REVIEW` - Under Review
        * `HEARING_PENDING` - Hearing Pending
        * `INVESTIGATION_PENDING` - Investigation Pending
        * `VERDICT_PENDING` - Verdict Pending
        * `CLOSED` - Closed
    CategoryEnum:
      enum:
      - ADMINISTRATIVE
      - THIRD_PARTY
      - DRILL
      type: string
      description: |-
        * `ADMINISTRATIVE` - Administrative
        * `THIRD_PARTY` - Third-Party Certified
        * `DRILL` - Drill
    ComplianceAlert:
      type: object
      properties:
        id:
          type: integer
          readOnly: true
        employee:
          type: integer
        employee_name:
          type: string
          readOnly: true
        alert_type:
          $ref: '#/components/schemas/AlertTypeEnum'
        status:
          $ref: '#/components/schemas/ComplianceAlertStatusEnum'
        title:
          type: string
          maxLength: 200
        description:
          type: string
        due_date:
          type: string
          format: date
        content_type:
          type: string
          maxLength: 50
        object_id:
          type: integer
          nullable: true
        acknowledged_at:
          type: string
          format: date-time
          readOnly: true
          nullable: true
        acknowledged_by:
          type: string
          maxLength: 200
        resolved_at:
          type: string
          format: date-time
          readOnly: true
          nullable: true
        created_at:
          type: string
          format: date-time
          readOnly: true
      required:
      - acknowledged_at
      - alert_type
      - created_at
      - description
      - due_date
      - employee
      - employee_name
      - id
      - resolved_at
      - title
    ComplianceAlertStatusEnum:
      enum:
      - ACTIVE
      - ACKNOWLEDGED
      - RESOLVED
      type: string
      description: |-
        * `ACTIVE` - Active
        * `ACKNOWLEDGED` - Acknowledged
        * `RESOLVED` - Resolved
    Contract:
      type: object
      properties:
        id:
          type: integer
          readOnly: true
        employee:
          type: integer
        employee_name:
          type: string
          readOnly: true
        contract_type:
          type: integer
        contract_type_name:
          type: string
          readOnly: true
        contract_number:
          type: string
          maxLength: 100
        start_date:
          type: string
          format: date
        end_date:
          type: string
          format: date
          nullable: true
        duration_months:
          type: integer
          nullable: true
        status:
          $ref: '#/components/schemas/ContractStatusEnum'
        salary_currency:
          type: string
          maxLength: 3
        basic_salary:
          type: string
          format: decimal
          pattern: ^-?\d{0,10}(?:\.\d{0,2})?$
          nullable: true
        document_url:
          type: string
          format: uri
          description: Link to contract document
          maxLength: 200
        is_expired:
          type: boolean
          readOnly: true
        days_until_expiry:
          type: integer
          readOnly: true
        created_at:
          type: string
          format: date-time
          readOnly: true
        updated_at:
          type: string
          format: date-time
          readOnly: true
      required:
      - contract_number
      - contract_type
      - contract_type_name
      - created_at
      - days_until_expiry
      - employee
      - employee_name
      - id
      - is_expired
      - start_date
      - updated_at
    ContractStatusEnum:
      enum:
      - ACTIVE
      - EXPIRED
      - RENEWED
      - TERMINATED
      - PENDING_RENEWAL
      type: string
      description: |-
        * `ACTIVE` - Active
        * `EXPIRED` - Expired
