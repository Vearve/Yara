  /api/v1/activities/reports/:
    get:
      operationId: api_v1_activities_reports_list
      description: ViewSet for safety, complaint, grievance, and disciplinary reports.
      parameters:
      - name: ordering
        required: false
        in: query
        description: Which field to use when ordering the results.
        schema:
          type: string
      - name: page
        required: false
        in: query
        description: A page number within the paginated result set.
        schema:
          type: integer
      - in: query
        name: report_type
        schema:
          type: integer
      - name: search
        required: false
        in: query
        description: A search term.
        schema:
          type: string
      - in: query
        name: severity
        schema:
          type: string
          enum:
          - CRITICAL
          - HIGH
          - LOW
          - MEDIUM
        description: |-
          * `LOW` - Low
          * `MEDIUM` - Medium
          * `HIGH` - High
          * `CRITICAL` - Critical
      - in: query
        name: status
        schema:
          type: string
          enum:
          - ACKNOWLEDGED
          - CLOSED
          - DRAFT
          - ESCALATED
          - SUBMITTED
        description: |-
          * `DRAFT` - Draft
          * `SUBMITTED` - Submitted
          * `ACKNOWLEDGED` - Acknowledged
          * `ESCALATED` - Escalated
          * `CLOSED` - Closed
      tags:
      - api
      security:
      - jwtAuth: []
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/PaginatedReportList'
          description: ''
    post:
      operationId: api_v1_activities_reports_create
      description: ViewSet for safety, complaint, grievance, and disciplinary reports.
