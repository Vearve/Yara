  /api/v1/activities/case-studies/:
    get:
      operationId: api_v1_activities_case_studies_list
      description: ViewSet for case studies linking reports to hearings/investigations.
      parameters:
      - name: ordering
        required: false
        in: query
        description: Which field to use when ordering the results.
        schema:
          type: string
      - name: page
        required: false
        in: query
        description: A page number within the paginated result set.
        schema:
          type: integer
      - name: search
        required: false
        in: query
        description: A search term.
        schema:
          type: string
      - in: query
        name: status
        schema:
          type: string
          enum:
          - CLOSED
          - HEARING_PENDING
          - INVESTIGATION_PENDING
          - OPENED
          - UNDER_REVIEW
          - VERDICT_PENDING
        description: |-
          * `OPENED` - Opened
          * `UNDER_REVIEW` - Under Review
          * `HEARING_PENDING` - Hearing Pending
          * `INVESTIGATION_PENDING` - Investigation Pending
          * `VERDICT_PENDING` - Verdict Pending
          * `CLOSED` - Closed
      tags:
      - api
      security:
      - jwtAuth: []
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/PaginatedCaseStudyList'
          description: ''
    post:
      operationId: api_v1_activities_case_studies_create
      description: ViewSet for case studies linking reports to hearings/investigations.
      tags:
      - api
      requestBody:
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/CaseStudy'
          application/x-www-form-urlencoded:
            schema:
              $ref: '#/components/schemas/CaseStudy'
          multipart/form-data:
            schema:
              $ref: '#/components/schemas/CaseStudy'
        required: true
      security:
      - jwtAuth: []
      responses:
        '201':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/CaseStudy'
          description: ''
