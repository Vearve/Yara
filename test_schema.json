components:
  schemas:
    ATR:
      type: object
      properties:
        id:
          type: integer
          readOnly: true
        reference_number:
          type: string
          maxLength: 50
        hiring_supervisor_name:
          type: string
          maxLength: 200
        position_title:
          type: string
          maxLength: 200
        roles_to_fill:
          type: integer
        due_date:
          type: string
          format: date
          nullable: true
        required_skills:
          type: string
          description: Required technical skills and competencies
        required_experience:
          type: string
          description: Years and type of experience required
        required_qualifications:
          type: string
          description: Education level and certifications required
        skill_sets:
          type: string
          description: Specific skill sets needed for the role
        budgeted:
          type: boolean
        budget_amount:
          type: string
          format: decimal
          pattern: ^-?\d{0,10}(?:\.\d{0,2})?$
          nullable: true
        actual_amount:
          type: string
          format: decimal
          pattern: ^-?\d{0,10}(?:\.\d{0,2})?$
          nullable: true
        zambian_junior:
          type: integer
        zambian_senior:
          type: integer
        expatriate:
          type: integer
        use_internal_db:
          type: boolean
        internal_advertising:
          type: boolean
        external_advertising:
          type: boolean
        hr_db_search:
          type: boolean
        recruitment_agencies:
          type: boolean
        hr_manager_name:
          type: string
          maxLength: 200
        hr_manager_signed_at:
          type: string
          format: date
          nullable: true
        ops_manager_name:
          type: string
          maxLength: 200
        ops_manager_signed_at:
          type: string
          format: date
          nullable: true
        director_name:
          type: string
          maxLength: 200
        director_signed_at:
          type: string
          format: date
          nullable: true
        notes:
          type: string
        created_at:
          type: string
          format: date-time
          readOnly: true
        updated_at:
          type: string
          format: date-time
          readOnly: true
        department:
          type: integer
      required:
      - created_at
      - department
      - hiring_supervisor_name
      - id
      - position_title
      - reference_number
      - updated_at
    Absenteeism:
      type: object
      properties:
        id:
          type: integer
          readOnly: true
        employee_name:
          type: string
          readOnly: true
        employee_code:
          type: string
          readOnly: true
        reported_by_name:
          type: string
          readOnly: true
        date:
          type: string
          format: date
          description: Date of absence
        status:
          $ref: '#/components/schemas/AbsenteeismStatusEnum'
        reason_provided:
          type: string
          description: Reason provided by employee
        supervisor_notes:
          type: string
          description: Supervisor/HR notes
        supporting_document:
          type: string
          format: uri
          nullable: true
        created_at:
          type: string
          format: date-time
          readOnly: true
        updated_at:
          type: string
          format: date-time
          readOnly: true
        employee:
          type: integer
        reported_by:
          type: integer
          readOnly: true
          nullable: true
      required:
      - created_at
      - date
      - employee
      - employee_code
      - employee_name
      - id
      - reported_by
      - reported_by_name
      - updated_at
    AbsenteeismStatusEnum:
      enum:
      - PENDING
      - JUSTIFIED
      - UNJUSTIFIED
      - UNDER_REVIEW
      type: string
      description: |-
        * `PENDING` - Pending
        * `JUSTIFIED` - Justified
        * `UNJUSTIFIED` - Unjustified
        * `UNDER_REVIEW` - Under Review
    ActionEnum:
      enum:
      - APPROVE
      - DENY
      type: string
      description: |-
        * `APPROVE` - APPROVE
        * `DENY` - DENY
    AgreedRatingEnum:
      enum:
      - 1
      - 2
      - 3
      - 4
      - 5
      type: integer
      description: |-
        * `1` - PP
        * `2` - SP
        * `3` - AP
        * `4` - AE
        * `5` - OP
    AlertTypeEnum:
      enum:
      - TRAINING
      - MEDICAL
      - PERMIT
      - CONTRACT
      - PROBATION
      type: string
      description: |-
        * `TRAINING` - Training Expiry
        * `MEDICAL` - Medical Expiry
        * `PERMIT` - Permit Expiry
        * `CONTRACT` - Contract Expiry
        * `PROBATION` - Probation Due
    Appraisal:
      type: object
      properties:
        id:
          type: integer
          readOnly: true
        appraisee:
          type: integer
        appraisee_name:
          type: string
          readOnly: true
        supervisor:
          type: integer
          nullable: true
        supervisor_name:
          type: string
          readOnly: true
        department:
          type: integer
          nullable: true
        department_name:
          type: string
          readOnly: true
        position_held:
          type: string
          maxLength: 200
        review_start:
          type: string
          format: date
        review_end:
          type: string
          format: date
        feedback_notes:
          type: string
          description: 180°/360° feedback summary
        employee_comments:
          type: string
        supervisor_comments:
          type: string
        employee_signed_at:
          type: string
          format: date-time
          nullable: true
        supervisor_signed_at:
          type: string
          format: date-time
          nullable: true
        overall_percentage:
          type: string
          format: decimal
          pattern: ^-?\d{0,3}(?:\.\d{0,2})?$
          nullable: true
        overall_rating:
          nullable: true
          oneOf:
          - $ref: '#/components/schemas/AgreedRatingEnum'
          - $ref: '#/components/schemas/NullEnum'
        attachment:
          type: string
          format: uri
          nullable: true
        created_at:
          type: string
          format: date-time
          readOnly: true
        updated_at:
          type: string
          format: date-time
          readOnly: true
      required:
      - appraisee
      - appraisee_name
      - created_at
      - department_name
      - id
      - position_held
      - review_end
      - review_start
      - supervisor_name
      - updated_at
    AppraisalDevelopmentItem:
      type: object
      properties:
        id:
          type: integer
          readOnly: true
        training_need:
          type: string
        action:
          type: string
        responsible:
          type: string
          maxLength: 200
        due_date:
          type: string
          format: date
          nullable: true
        application_note:
          type: string
          description: How learning will be applied
        review_date:
          type: string
          format: date
          nullable: true
      required:
      - id
      - training_need
    AppraisalFactor:
      type: object
      properties:
        id:
          type: integer
          readOnly: true
        group:
          $ref: '#/components/schemas/GroupEnum'
        name:
          type: string
          maxLength: 200
        rating:
          nullable: true
          oneOf:
          - $ref: '#/components/schemas/AgreedRatingEnum'
          - $ref: '#/components/schemas/NullEnum'
        notes:
          type: string
        order:
          type: integer
      required:
      - group
      - id
      - name
    AppraisalImprovementItem:
      type: object
      properties:
        id:
          type: integer
          readOnly: true
        issue:
          type: string
          description: Objectives not achieved / challenges / areas for improvement
        limiting_factors:
          type: string
        actions:
          type: string
        completion_indicator:
          type: string
        due_date:
          type: string
          format: date
          nullable: true
      required:
      - id
      - issue
    AppraisalNextObjective:
      type: object
      properties:
        id:
          type: integer
          readOnly: true
        key_area:
          type: string
          maxLength: 200
        objective:
          type: string
          description: SMART objective for next period
        indicators:
          type: string
          description: How achievement will be measured
      required:
      - id
      - objective
    AppraisalObjective:
      type: object
      properties:
        id:
          type: integer
          readOnly: true
        title:
          type: string
          description: State Performance Objective
        self_rating:
          nullable: true
          oneOf:
          - $ref: '#/components/schemas/AgreedRatingEnum'
          - $ref: '#/components/schemas/NullEnum'
        supervisor_rating:
          nullable: true
          oneOf:
          - $ref: '#/components/schemas/AgreedRatingEnum'
          - $ref: '#/components/schemas/NullEnum'
        agreed_rating:
          nullable: true
          oneOf:
          - $ref: '#/components/schemas/AgreedRatingEnum'
          - $ref: '#/components/schemas/NullEnum'
        comments:
          type: string
        order:
          type: integer
      required:
      - id
      - title
    AssignedRoleEnum:
      enum:
      - OWNER
      - ADMIN
      - HR_MANAGER
      - MANAGER
      - VIEWER
      type: string
      description: |-
        * `OWNER` - Owner
        * `ADMIN` - Administrator
        * `HR_MANAGER` - HR Manager
        * `MANAGER` - Manager
        * `VIEWER` - Viewer
    Assignment:
      type: object
      properties:
        id:
          type: integer
          readOnly: true
        employee:
          type: integer
        employee_name:
          type: string
          readOnly: true
        site:
          type: integer
        site_name:
          type: string
          readOnly: true
        project:
          type: integer
          nullable: true
        project_name:
          type: string
          readOnly: true
        client:
          type: integer
          description: Client paying for/receiving contractor
        client_name:
          type: string
          readOnly: true
        status:
          $ref: '#/components/schemas/AssignmentStatusEnum'
        assignment_start_date:
          type: string
          format: date
        assignment_end_date:
          type: string
          format: date
          nullable: true
        role_at_site:
          type: string
          description: Role specific to this assignment
          maxLength: 200
        shift:
          type: string
          description: e.g., Day, Night, Rotating
          maxLength: 50
        visible_to_client:
          type: boolean
          description: Can client see this assignment?
        is_current:
          type: boolean
          readOnly: true
        created_at:
          type: string
          format: date-time
          readOnly: true
        updated_at:
          type: string
          format: date-time
          readOnly: true
      required:
      - assignment_start_date
      - client
      - client_name
      - created_at
      - employee
      - employee_name
      - id
      - is_current
      - project_name
      - site
      - site_name
      - updated_at
    AssignmentStatusEnum:
      enum:
      - ACTIVE
      - SUSPENDED
      - ENDED
      type: string
      description: |-
        * `ACTIVE` - Active
        * `SUSPENDED` - Suspended
        * `ENDED` - Ended
    BlankEnum:
      enum:
      - ''
    Candidate:
      type: object
      properties:
        id:
          type: integer
          readOnly: true
        atr_reference:
          type: string
          readOnly: true
        engaged_date:
          type: string
          format: date
        name:
          type: string
          maxLength: 200
        nrc:
          type: string
          maxLength: 50
        phone_number:
          type: string
          maxLength: 30
        position:
          type: string
          maxLength: 200
        agreed_net_pay:
          type: string
          maxLength: 100
        accommodation:
          type: string
          maxLength: 200
        docs_submitted:
          type: boolean
        recommendation_date:
          type: string
