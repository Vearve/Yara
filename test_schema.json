    get:
      operationId: api_v1_payroll_payslips_list
      description: ViewSet for employee payslips with Zambian statutory calculations
      parameters:
      - in: query
        name: employee
        schema:
          type: integer
      - in: query
        name: is_active
        schema:
          type: boolean
      - in: query
        name: is_processed
        schema:
          type: boolean
      - name: ordering
        required: false
        in: query
        description: Which field to use when ordering the results.
        schema:
          type: string
      - name: page
        required: false
        in: query
        description: A page number within the paginated result set.
        schema:
          type: integer
      - in: query
        name: period
        schema:
          type: integer
      - in: query
        name: period__month
        schema:
          type: integer
          enum:
          - 1
          - 10
          - 11
          - 12
          - 2
          - 3
          - 4
          - 5
          - 6
          - 7
          - 8
          - 9
        description: |-
          * `1` - January
          * `2` - February
          * `3` - March
          * `4` - April
          * `5` - May
          * `6` - June
          * `7` - July
          * `8` - August
          * `9` - September
          * `10` - October
          * `11` - November
          * `12` - December
      - in: query
        name: period__year
        schema:
          type: integer
      - name: search
        required: false
        in: query
        description: A search term.
        schema:
          type: string
