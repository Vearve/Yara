        termination_reason_name:
          type: string
          readOnly: true
        payroll_final:
          type: boolean
          description: Final payroll processed
        comments:
          type: string
        created_at:
          type: string
          format: date-time
          readOnly: true
        updated_at:
          type: string
          format: date-time
          readOnly: true
      required:
      - created_at
      - employee
      - employee_name
      - id
      - termination_date
      - termination_reason
      - termination_reason_name
      - updated_at
    TerminationReason:
      type: object
      properties:
        id:
          type: integer
          readOnly: true
        name:
          $ref: '#/components/schemas/TerminationReasonNameEnum'
        description:
          type: string
      required:
      - id
      - name
    TerminationReasonNameEnum:
      enum:
      - RESIGNATION
      - REDUNDANCY
      - RETIREMENT
      - TERMINATED
      - ENDED
      - DECEASED
      - OTHER
      type: string
      description: |-
        * `RESIGNATION` - Resignation
        * `REDUNDANCY` - Redundancy
        * `RETIREMENT` - Retirement
        * `TERMINATED` - Terminated
        * `ENDED` - Contract Ended
        * `DECEASED` - Deceased
        * `OTHER` - Other
    TitleBreakdown:
      type: object
      properties:
        id:
          type: integer
          readOnly: true
        position:
          type: string
          maxLength: 200
        currency:
          type: string
          default: ZMW
          maxLength: 3
        basic:
          type: string
          format: decimal
          pattern: ^-?\d{0,10}(?:\.\d{0,2})?$
        housing:
          type: string
          format: decimal
          pattern: ^-?\d{0,10}(?:\.\d{0,2})?$
        transportation:
          type: string
          format: decimal
          pattern: ^-?\d{0,10}(?:\.\d{0,2})?$
        lunch:
          type: string
          format: decimal
          pattern: ^-?\d{0,10}(?:\.\d{0,2})?$
        gross:
          type: string
          format: decimal
          pattern: ^-?\d{0,10}(?:\.\d{0,2})?$
        net:
          type: string
          format: decimal
          pattern: ^-?\d{0,10}(?:\.\d{0,2})?$
        updated_at:
          type: string
          format: date-time
          readOnly: true
      required:
      - id
      - position
      - updated_at
    TokenRefresh:
      type: object
      properties:
        access:
          type: string
          readOnly: true
        refresh:
          type: string
          writeOnly: true
      required:
      - access
      - refresh
    Training:
      type: object
      properties:
        id:
          type: integer
          readOnly: true
        employee:
          type: integer
        employee_name:
          type: string
          readOnly: true
        training_type:
          type: integer
        training_type_detail:
          allOf:
          - $ref: '#/components/schemas/TrainingType'
          readOnly: true
        provider:
          type: string
          maxLength: 200
        status:
          $ref: '#/components/schemas/TrainingStatusEnum'
        scheduled_date:
          type: string
          format: date
        completion_date:
          type: string
          format: date
          nullable: true
        issue_date:
          type: string
          format: date
          nullable: true
        expiry_date:
          type: string
          format: date
          nullable: true
        certificate_number:
          type: string
          maxLength: 100
        certificate_document:
          type: string
          format: uri
        cost:
          type: string
          format: decimal
          pattern: ^-?\d{0,8}(?:\.\d{0,2})?$
          nullable: true
        notes:
          type: string
        is_expired:
          type: boolean
          readOnly: true
        days_until_expiry:
          type: integer
          readOnly: true
        created_at:
          type: string
          format: date-time
          readOnly: true
        updated_at:
          type: string
          format: date-time
          readOnly: true
      required:
      - created_at
      - days_until_expiry
      - employee
      - employee_name
      - id
      - is_expired
      - provider
      - scheduled_date
      - training_type
      - training_type_detail
      - updated_at
    TrainingStatusEnum:
      enum:
      - SCHEDULED
      - IN_PROGRESS
      - COMPLETED
      - CANCELLED
      type: string
      description: |-
        * `SCHEDULED` - Scheduled
        * `IN_PROGRESS` - In Progress
        * `COMPLETED` - Completed
        * `CANCELLED` - Cancelled
    TrainingType:
      type: object
      properties:
        id:
          type: integer
          readOnly: true
        name:
          type: string
          maxLength: 200
        category:
          $ref: '#/components/schemas/CategoryEnum'
        description:
          type: string
        requires_certification:
          type: boolean
        default_validity_months:
          type: integer
          nullable: true
      required:
      - category
      - id
      - name
    UserBasic:
      type: object
      properties:
        id:
          type: integer
          readOnly: true
        username:
          type: string
          description: Required. 150 characters or fewer. Letters, digits and @/./+/-/_
            only.
          pattern: ^[\w.@+-]+$
          maxLength: 150
        email:
          type: string
          format: email
          title: Email address
          maxLength: 254
        first_name:
          type: string
          maxLength: 150
        last_name:
          type: string
          maxLength: 150
      required:
      - id
      - username
    VerdictEnum:
      enum:
      - GUILTY
      - NOT_GUILTY
      - SETTLED
      - DISMISSED
      - PENDING
      type: string
      description: |-
        * `GUILTY` - Guilty
        * `NOT_GUILTY` - Not Guilty
        * `SETTLED` - Settled
        * `DISMISSED` - Dismissed
        * `PENDING` - Pending
    Workspace:
      type: object
      properties:
        id:
          type: integer
          readOnly: true
        name:
          type: string
          description: Organization name
          maxLength: 200
        code:
          type: string
          description: Short code/abbreviation
          maxLength: 50
        workspace_type:
          $ref: '#/components/schemas/WorkspaceTypeEnum'
        description:
          type: string
        industry:
          type: string
          description: e.g., Mining, Construction
          maxLength: 100
        contact_email:
          type: string
          format: email
          maxLength: 254
        contact_phone:
          type: string
          maxLength: 20
        address:
          type: string
        is_active:
          type: boolean
        created_at:
          type: string
          format: date-time
          readOnly: true
        updated_at:
          type: string
          format: date-time
          readOnly: true
        member_count:
          type: string
          readOnly: true
        employee_count:
          type: string
          readOnly: true
      required:
      - code
      - created_at
      - employee_count
      - id
      - member_count
      - name
      - updated_at
    WorkspaceAccessRequest:
      type: object
      description: Serializer for workspace access requests
      properties:
        id:
          type: integer
          readOnly: true
        workspace:
          type: integer
        requesting_user:
          type: integer
          readOnly: true
        message:
          type: string
          description: Why the user wants access
        status:
          allOf:
          - $ref: '#/components/schemas/WorkspaceAccessRequestStatusEnum'
          readOnly: true
          default: PENDING
        processed_by:
          type: integer
          readOnly: true
          nullable: true
        processed_at:
          type: string
          format: date-time
          readOnly: true
          nullable: true
        admin_notes:
          type: string
          description: Internal notes from admin
        assigned_role:
          oneOf:
          - $ref: '#/components/schemas/AssignedRoleEnum'
          - $ref: '#/components/schemas/BlankEnum'
        assigned_custom_role:
          type: integer
          nullable: true
        requested_at:
          type: string
          format: date-time
          readOnly: true
        requesting_user_details:
          allOf:
          - $ref: '#/components/schemas/UserBasic'
          readOnly: true
        workspace_details:
          allOf:
          - $ref: '#/components/schemas/Workspace'
          readOnly: true
        processed_by_details:
          allOf:
          - $ref: '#/components/schemas/UserBasic'
          readOnly: true
      required:
      - id
      - processed_at
      - processed_by
      - processed_by_details
      - requested_at
      - requesting_user
      - requesting_user_details
      - status
      - workspace
      - workspace_details
    WorkspaceAccessRequestCreate:
      type: object
      description: Serializer for creating access requests
      properties:
        workspace:
          type: integer
        message:
          type: string
          description: Why the user wants access
      required:
      - workspace
    WorkspaceAccessRequestProcess:
      type: object
      description: Serializer for approving/denying access requests
      properties:
        action:
          $ref: '#/components/schemas/ActionEnum'
        admin_notes:
          type: string
        assigned_role:
          $ref: '#/components/schemas/AssignedRoleEnum'
        assigned_custom_role:
          type: integer
          nullable: true
      required:
      - action
    WorkspaceAccessRequestStatusEnum:
      enum:
      - PENDING
      - APPROVED
      - DENIED
      type: string
      description: |-
        * `PENDING` - Pending
        * `APPROVED` - Approved
        * `DENIED` - Denied
    WorkspaceAwareTokenObtainPair:
      type: object
      properties:
        workspace_id:
          type: integer
          nullable: true
        username:
          type: string
          writeOnly: true
        password:
          type: string
          writeOnly: true
      required:
      - password
      - username
    WorkspaceMembership:
      type: object
      properties:
        id:
          type: integer
          readOnly: true
        user:
          type: integer
        workspace:
          type: integer
        role:
          $ref: '#/components/schemas/RoleEnum'
        is_default:
          type: boolean
          description: Default workspace to load on login
        is_active:
          type: boolean
        joined_at:
          type: string
          format: date-time
          readOnly: true
        invited_by:
          type: integer
          nullable: true
        user_details:
          allOf:
          - $ref: '#/components/schemas/UserBasic'
          readOnly: true
        workspace_details:
          allOf:
          - $ref: '#/components/schemas/Workspace'
          readOnly: true
      required:
      - id
      - joined_at
      - user
      - user_details
      - workspace
      - workspace_details
    WorkspaceTypeEnum:
      enum:
      - COMPANY
      - CONTRACTOR_FIRM
      - CONSULTANT
      type: string
      description: |-
        * `COMPANY` - Company
        * `CONTRACTOR_FIRM` - Contractor Firm
        * `CONSULTANT` - Consultant/Advisor
    WorkspaceUserCreate:
      type: object
      properties:
        email:
          type: string
          format: email
        first_name:
          type: string
        last_name:
          type: string
        username:
          type: string
        password:
          type: string
          writeOnly: true
        role:
          allOf:
          - $ref: '#/components/schemas/RoleEnum'
          default: VIEWER
      required:
      - email
  securitySchemes:
    jwtAuth:
      type: http
      scheme: bearer
      bearerFormat: JWT
servers:
- url: http://localhost:8000
  description: Local development
- url: https://api.hrms.zm
  description: Production
